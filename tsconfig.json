{
	"compilerOptions": {
		"jsx": "react-jsx",
		"moduleResolution": "Bundler",
		"module": "ESNext",
		"target": "ES2022",
		"skipLibCheck": true,
		"strictNullChecks": true,
		"strict": true,
		"noEmit": true,
		"allowImportingTsExtensions": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"types": ["vite/client", "node", "bun"],
		"paths": {
			"~/*": ["./src/*"]
		}
	},
	"include": [
		"src/**/*",
		"scripts/**/*",
		"server.ts",
		"vite.config.ts",
		"drizzle.config.ts"
	],
	"exclude": ["node_modules", "dist", "drizzle"]
}
